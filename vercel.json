{
  "installCommand": "rm -f package-lock.json npm-shrinkwrap.json && npm install --registry=https://registry.npmjs.org/ --no-package-lock --no-audit --no-fund --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/generate.ts": {
      "maxDuration": 60
    }
  }
}
